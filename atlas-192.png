<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1024 1365">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="0" y2="1">
      <stop offset="0" stop-color="#0F1428"/>
      <stop offset="0.6" stop-color="#1A1F3A"/>
      <stop offset="1" stop-color="#232949"/>
    </linearGradient>
    <radialGradient id="glow" cx="0.5" cy="0.5" r="0.5">
      <stop offset="0" stop-color="#C9A961" stop-opacity="0.08"/>
      <stop offset="1" stop-color="#C9A961" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1024" height="1365" fill="url(#bg)"/>
  <rect x="200" y="400" width="624" height="624" fill="url(#glow)"/>
  <!-- Outer frame -->
  <rect x="36" y="36" width="952" height="1293" fill="none" stroke="#C9A961" stroke-width="2" stroke-opacity="0.9"/>
  <rect x="52" y="52" width="920" height="1261" fill="none" stroke="#C9A961" stroke-width="1" stroke-opacity="0.35"/>
  <!-- Corner fittings -->
  <g stroke="#C9A961" stroke-width="2.5" fill="none">
    <path d="M36 96 L36 36 L96 36"/>
    <path d="M988 96 L988 36 L928 36"/>
    <path d="M36 1269 L36 1329 L96 1329"/>
    <path d="M988 1269 L988 1329 L928 1329"/>
  </g>
  <!-- Silhouette: Knight — saber diagonal -->
  <g stroke="#C9A961" stroke-width="2" fill="none" stroke-linecap="round">
    <!-- Head -->
    <ellipse cx="512" cy="560" rx="70" ry="82"/>
    <!-- Shoulders / coat -->
    <path d="M380 720 Q420 680 512 680 Q604 680 644 720 L670 960 L354 960 Z" stroke-opacity="0.75"/>
    <!-- Coat lapels -->
    <path d="M470 700 L500 870 M554 700 L524 870" stroke-opacity="0.5"/>
    <!-- Saber -->
    <path d="M640 760 L880 540" stroke-width="3"/>
    <path d="M632 752 L648 768" stroke-width="4"/>
  </g>
  <!-- Class label -->
  <text x="512" y="1110" text-anchor="middle" font-family="Cinzel, Georgia, serif" font-size="88" font-weight="600" fill="#C9A961" letter-spacing="18">KNIGHT</text>
  <text x="512" y="1170" text-anchor="middle" font-family="'Cormorant Garamond', Georgia, serif" font-size="38" font-style="italic" fill="#E8E1CC" opacity="0.7">Eques Masculinus</text>
  <text x="512" y="1230" text-anchor="middle" font-family="'Shippori Mincho B1', serif" font-size="30" fill="#E8E1CC" letter-spacing="8">騎士 ・ 男性型</text>
  <!-- Placeholder marker -->
  <text x="512" y="1290" text-anchor="middle" font-family="serif" font-size="18" fill="#E8E1CC" opacity="0.3" letter-spacing="6">— PLACEHOLDER —</text>
</svg>
